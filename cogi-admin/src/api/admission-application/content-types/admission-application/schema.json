{
  "kind": "collectionType",
  "collectionName": "admission_applications",
  "info": {
    "singularName": "admission-application",
    "pluralName": "admission-applications",
    "displayName": "AdmissionApplication",
    "description": "Tenant-scoped admission applications submitted by parents."
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "tenant": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::tenant.tenant",
      "inversedBy": "admissionApplications",
      "required": true
    },
    "campaign": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::campaign.campaign",
      "inversedBy": "admissionApplications",
      "required": true
    },
    "parent": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user",
      "required": true
    },
    "applicationCode": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "admissionStatus": {
      "type": "enumeration",
      "enum": [
        "draft",
        "submitted",
        "reviewing",
        "approved",
        "rejected",
        "exam_scheduled",
        "passed",
        "failed",
        "enrolled"
      ],
      "required": true,
      "default": "draft"
    },
    "studentName": {
    "type": "string"
    },
    "studentCode": {
      "type": "string",
      "index": true
    },
    "dob": {
    "type": "date"
    },
    "gender": {
      "type": "enumeration",
      "enum": [
        "male",
        "female",
        "other"
      ]
    },
    "currentSchool": {
      "type": "string"
    },
    "address": {
      "type": "text"
    },
    "formData": {
      "type": "json"
    },
    "reviewSnapshot": {
      "type": "json"
    },
    "formTemplateVersion": {
      "type": "integer"
    },
    "submittedAt": {
      "type": "datetime"
    },
    "reviewStatus": {
      "type": "enumeration",
      "enum": [
        "submitted",
        "returned",
        "accepted"
      ]
    },
    "reviewedBy": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user"
    },
    "reviewedAt": {
      "type": "datetime"
    },
    "reviewNote": {
      "type": "text"
    },
    "isDeleted": {
      "type": "boolean",
      "default": false
    },
    "deletedAt": {
      "type": "datetime"
    },
    "deletedBy": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user"
    },
    "deleteReason": {
      "type": "text"
    },
    "restoredAt": {
      "type": "datetime"
    },
    "restoredBy": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user"
    },
    "restoreReason": {
      "type": "text"
    },
    "approvalNotifiedAt": {
      "type": "datetime"
    },
    "approvalNotificationCount": {
      "type": "integer",
      "default": 0
    },
    "approvedAcknowledgedAt": {
      "type": "datetime"
    },
    "approvedAcknowledgedBy": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user"
    },
    "approvedAcknowledgedNote": {
      "type": "text"
    },
    "messages": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::admission-application-message.admission-application-message",
      "mappedBy": "application"
    },
    "activities": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::admission-application-activity.admission-application-activity",
      "mappedBy": "application"
    },
    "parentLastOpenedAt": {
      "type": "datetime"
    },
    "schoolLastOpenedAt": {
      "type": "datetime"
    },
    "parentUnreadMessageCount": {
      "type": "integer",
      "default": 0
    },
    "schoolUnreadMessageCount": {
      "type": "integer",
      "default": 0
    },
    "lastMessageAt": {
      "type": "datetime"
    },
    "lastActivityAt": {
      "type": "datetime"
    },
    "applicationFiles": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::admission-application-file.admission-application-file",
      "mappedBy": "application"
    }
  }
}