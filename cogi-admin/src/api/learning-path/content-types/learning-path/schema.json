{
  "kind": "collectionType",
  "collectionName": "learning_paths",
  "info": {
    "singularName": "learning-path",
    "pluralName": "learning-paths",
    "displayName": "Learning Path",
    "description": "Tenant-scoped ordered learning path."
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "code": {
      "type": "string",
      "required": true
    },
    "title": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "learningPathStatus": {
      "type": "enumeration",
      "enum": [
        "draft",
        "active",
        "archived"
      ],
      "default": "draft",
      "required": true
    },
    "subject": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::subject.subject",
      "inversedBy": "learningPaths"
    },
    "grade": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::grade.grade",
      "inversedBy": "learningPaths"
    },
    "items": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::learning-path-item.learning-path-item",
      "mappedBy": "learningPath"
    },
    "tenant": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::tenant.tenant",
      "inversedBy": "learningPaths",
      "required": true
    }
  }
}