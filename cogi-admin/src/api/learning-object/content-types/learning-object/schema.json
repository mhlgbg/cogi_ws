{
  "kind": "collectionType",
  "collectionName": "learning_objects",
  "info": {
    "singularName": "learning-object",
    "pluralName": "learning-objects",
    "displayName": "Learning Object",
    "description": "Tenant-scoped reusable learning object."
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "code": {
      "type": "string",
      "required": true
    },
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "version": {
      "type": "string"
    },
    "learningObjectStatus": {
      "type": "enumeration",
      "enum": [
        "draft",
        "active",
        "archived"
      ],
      "default": "draft",
      "required": true
    },
    "difficulty": {
      "type": "enumeration",
      "enum": [
        "easy",
        "medium",
        "hard"
      ]
    },
    "estimatedMinutes": {
      "type": "integer"
    },
    "learningObjectives": {
      "type": "json"
    },
    "tags": {
      "type": "json"
    },
    "metadata": {
      "type": "json"
    },
    "subject": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::subject.subject",
      "inversedBy": "learningObjects"
    },
    "grade": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::grade.grade",
      "inversedBy": "learningObjects"
    },
    "knowledgeNodes": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::knowledge-node.knowledge-node",
      "inversedBy": "learningObjects"
    },
    "prerequisites": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::learning-object.learning-object",
      "inversedBy": "dependentLearningObjects"
    },
    "dependentLearningObjects": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::learning-object.learning-object",
      "mappedBy": "prerequisites"
    },
    "contentBlocks": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::content-block.content-block",
      "mappedBy": "learningObject"
    },
    "skills": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::skill.skill",
      "inversedBy": "learningObjects"
    },
    "formulas": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::formula.formula",
      "inversedBy": "learningObjects"
    },
    "questions": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::question.question",
      "inversedBy": "learningObjects"
    },
    "visualAssets": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::visual-asset.visual-asset",
      "inversedBy": "learningObjects"
    },
    "learningPathItems": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::learning-path-item.learning-path-item",
      "mappedBy": "learningObject"
    },
    "studentProgressRecords": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::student-learning-object-progress.student-learning-object-progress",
      "mappedBy": "learningObject"
    },
    "tenant": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::tenant.tenant",
      "inversedBy": "learningObjects",
      "required": true
    }
  }
}