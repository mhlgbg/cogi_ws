{
  "kind": "collectionType",
  "collectionName": "knowledge_nodes",
  "info": {
    "singularName": "knowledge-node",
    "pluralName": "knowledge-nodes",
    "displayName": "Knowledge Node",
    "description": "Tenant-scoped knowledge tree node."
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "code": {
      "type": "string",
      "required": true
    },
    "title": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "order": {
      "type": "integer",
      "default": 0
    },
    "level": {
      "type": "integer",
      "default": 0
    },
    "knowledgeNodeStatus": {
      "type": "enumeration",
      "enum": [
        "active",
        "archived"
      ],
      "default": "active",
      "required": true
    },
    "subject": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::subject.subject",
      "inversedBy": "knowledgeNodes"
    },
    "grade": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::grade.grade",
      "inversedBy": "knowledgeNodes"
    },
    "parent": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::knowledge-node.knowledge-node",
      "inversedBy": "children"
    },
    "children": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::knowledge-node.knowledge-node",
      "mappedBy": "parent"
    },
    "learningObjects": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::learning-object.learning-object",
      "mappedBy": "knowledgeNodes"
    },
    "skills": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::skill.skill",
      "mappedBy": "knowledgeNode"
    },
    "formulas": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::formula.formula",
      "mappedBy": "knowledgeNode"
    },
    "questions": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::question.question",
      "mappedBy": "knowledgeNode"
    },
    "visualAssets": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::visual-asset.visual-asset",
      "mappedBy": "knowledgeNode"
    },
    "tenant": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::tenant.tenant",
      "inversedBy": "knowledgeNodes",
      "required": true
    }
  }
}