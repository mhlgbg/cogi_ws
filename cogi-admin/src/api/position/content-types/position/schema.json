{
  "kind": "collectionType",
  "collectionName": "positions",
  "info": {
    "singularName": "position",
    "pluralName": "positions",
    "displayName": "Position"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "code": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name"
    },
    "level": {
      "type": "integer",
      "default": 1
    },
    "isLeadership": {
      "type": "boolean",
      "default": false
    },
    "isActive": {
      "type": "boolean",
      "default": true
    },
    "description": {
      "type": "text"
    }
  }
}
