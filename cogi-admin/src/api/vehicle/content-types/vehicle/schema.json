{
  "kind": "collectionType",
  "collectionName": "vehicles",
  "info": {
    "singularName": "vehicle",
    "pluralName": "vehicles",
    "displayName": "Vehicle"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "code": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "slug": {
      "type": "uid",
      "targetField": "title"
    },
    "vehicleType": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::vehicle-type.vehicle-type",
      "inversedBy": "vehicles"
    },
    "pricePerDayFrom": {
      "type": "decimal"
    },
    "depositFrom": {
      "type": "decimal"
    },
    "location": {
      "type": "string"
    },
    "images": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "shortDesc": {
      "type": "text"
    },
    "features": {
      "type": "json"
    },
    "isFeatured": {
      "type": "boolean"
    },
    "isActive": {
      "type": "boolean"
    },
    "leads": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::lead.lead",
      "mappedBy": "vehicle"
    }
  }
