{
  "kind": "collectionType",
  "collectionName": "request_categories",
  "info": {
    "singularName": "request-category",
    "pluralName": "request-categories",
    "displayName": "RequestCategory"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string"
    },
    "slug": {
      "type": "uid",
      "targetField": "name"
    },
    "isActive": {
      "type": "boolean"
    },
    "description": {
      "type": "text"
    },
    "parent": {
