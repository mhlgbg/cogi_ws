{
  "kind": "collectionType",
  "collectionName": "vehicle_types",
  "info": {
    "singularName": "vehicle-type",
    "pluralName": "vehicle-types",
    "displayName": "VehicleType"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string"
    },
    "slug": {
      "type": "uid",
      "targetField": "name"
    },
    "sortOrder": {
      "type": "integer"
    },
    "isActive": {
      "type": "boolean"
    },
    "vehicles": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::vehicle.vehicle",
      "mappedBy": "vehicleType"
    },
    "leads": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::lead.lead",
      "mappedBy": "vehicleType"
    },
    "cover": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "shortDesc": {
      "type": "text"
    }
  }
}
